package Array;

public class Commonelements {
	public static void main(String[] args) {
		int arr1[] = {1,3,5,7};
		int arr2[] = {2,3,5,6};
		
		System.out.println("common elements:");
		
		for (int i= 0 ; i < arr1.length;i++) {
			for (int j=0 ; j < arr2.length;j++) {
				if (arr1[i]==arr2[j]) {
					System.out.print(arr1[i]+" ");
				}
				
			}
		}

	}

}
